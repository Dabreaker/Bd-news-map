# ─── Set these in Vercel Dashboard → Settings → Environment Variables ───
#
# STORAGE_URL:
#   The .onion URL from your phone's db_link.txt
#   Example: http://abc123xyz789.onion
#   Vercel will auto-convert this to https://abc123xyz789.onion.ws (tor2web)
#
# WRITE_SECRET:
#   Must match WRITE_SECRET in your phone's .env file exactly
#   Used to verify that writes come from your Vercel app only
#   Generate one: openssl rand -hex 32
#
STORAGE_URL=http://YOUR_ONION_ADDRESS.onion
WRITE_SECRET=your-random-secret-here
